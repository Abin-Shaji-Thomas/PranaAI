# PranaAI Environment Configuration
# Copy this file to .env and fill in your API keys

# ScaleDown API (Required for context compression)
SCALEDOWN_API_KEY=your_scaledown_api_key_here

# OpenAI API (Required for LLM reasoning)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Alternative: Gemini API (if using Gemini Flash instead)
# GEMINI_API_KEY=your_gemini_api_key_here

# Model Configuration
LLM_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=18
SCALEDOWN_MODEL=gpt-4o-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# System Configuration
MAX_RETRIEVAL_DOCS=5
SCALEDOWN_COMPRESSION_RATE=auto
SCALEDOWN_MIN_TOKENS=220
TARGET_LATENCY_MS=500
DECISION_POLICY_PATH=data/processed/decision_policy.json
FORCE_STRICT_SLA_ALL_REQUESTS=true
FAST_MODE_SKIP_RETRIEVAL=false
FAST_MODE_HISTORY_MAX_CHARS=3200
FAST_MODE_SCALEDOWN_TIMEOUT_MS=200

# API Server
API_HOST=0.0.0.0
API_PORT=8000
